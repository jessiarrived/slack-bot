# Bot (xoxb-): chat.postMessage, Socket events — scopes e.g. chat:write, channels:read, app_mentions:read
SLACK_BOT_TOKEN=
# User OAuth (xoxp-): conversations.history / conversations.replies — scopes e.g. channels:history,
# channels:read, groups:history, groups:read, search:read (add im:history/mpim:history for DM threads)
SLACK_USER_TOKEN=
SLACK_APP_TOKEN=

# Choose ONE provider:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: Postgres table for message logging (must match your schema)
# SUPABASE_MESSAGES_TABLE=slack_messages
